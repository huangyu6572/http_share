{
  "name": "prompts-manager",
  "displayName": "Prompts Manager",
  "description": "Record and manage prompts (title + content) and insert them into the editor. Shows a status-bar task icon to open the manager.",
  "version": "0.0.1",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onCommand:prompts.show"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prompts.show",
        "title": "Prompts: Show Manager"
      }
    ]
  },
  "scripts": {},
  "keywords": [
    "prompts",
    "copilot",
    "prompts-manager"
  ],
  "author": "",
  "license": "MIT"
}
